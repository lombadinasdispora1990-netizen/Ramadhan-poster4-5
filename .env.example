# --- KONFIGURASI UNTUK QODER AGENT (Koding) ---
# Gunakan sk-sp- untuk membantu Qoder menulis kode
VITE_CODING_API_KEY=
VITE_CODING_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/v1

# --- KONFIGURASI UNTUK APLIKASI (Generate Poster) ---
# Gunakan sk-9bd untuk fitur Utama Aplikasi (Singapore Region)
VITE_ALIBABA_API_KEY=

# Konfigurasi Teks (Qwen3.5-Flash - More Accurate)
VITE_API_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1/chat/completions
VITE_MODEL_NAME=qwen3.5-flash

# Konfigurasi Gambar (Wan2.6 Image-to-Image)
VITE_WANX_API_URL=https://dashscope-intl.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
VITE_WANX_MODEL=wan2.6-image